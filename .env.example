NODE_ENV=production
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
SERVICE_API_KEY=

REDIS_HOST=redis
REDIS_PORT=6379

AZURE_TIER=F0
AZURE_ENDPOINT=
AZURE_KEY=
AZURE_API_VERSION=2024-11-30
AZURE_MODEL_ID=prebuilt-layout
AZURE_REQUEST_TIMEOUT_MS=30000
AZURE_OPERATION_TIMEOUT_MS=120000
AZURE_POLL_INTERVAL_MS=2000
AZURE_MAX_RETRIES=3
AZURE_RETRY_BASE_DELAY_MS=1000
AZURE_SUBMIT_REQUESTS_PER_SECOND=1
AZURE_POLL_REQUESTS_PER_SECOND=1

MAX_FILE_SIZE_MB=50
MAX_BATCH_SIZE_MB=250
AZURE_MAX_INPUT_SIZE_MB=4
FILE_WORKER_CONCURRENCY=3
FILE_JOB_MAX_ATTEMPTS=3
FILE_JOB_BACKOFF_MS=1000
JOB_TTL_HOURS=24
IDEMPOTENCY_TTL_HOURS=24
CLEANUP_INTERVAL_MINUTES=60
API_UPLOAD_REQUESTS_PER_MINUTE=30
API_STATUS_REQUESTS_PER_MINUTE=300
TEMP_DIR=/app/tmp
